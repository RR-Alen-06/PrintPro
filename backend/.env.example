# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ── Database (Supabase PostgreSQL) ─────────────────
# Direct PostgreSQL connection string (takes precedence if provided)
DATABASE_URL=
# Or provide the database password created during Supabase project setup
# (The system will auto-construct the connection string using this password)
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ── Supabase ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
