# ==============================================================================
# PRINTPRO GLOBAL ENVIRONMENT TEMPLATE
# ==============================================================================
# This file serves as a reference for all environment variables used by the
# frontend and backend. Copy the respective sections into your local files.
#
# Backend location: backend/.env
# Frontend location: frontend/.env
# ==============================================================================

# ==============================================================================
# SECTION 1: FRONTEND ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# The public Supabase project URL (e.g. https://xyz.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The public Supabase client anonymous API key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# The local or production base URL of your API
VITE_API_BASE_URL=http://localhost:5000/api


# ==============================================================================
# SECTION 2: BACKEND ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# Node environment (development, production)
NODE_ENV=development

# Server port to bind on
PORT=5000

# Logging severity level (error, warn, info, debug)
LOG_LEVEL=info

# Direct PostgreSQL database connection URL (takes precedence if provided)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
DATABASE_URL=

# Alternatively, specify the Supabase PostgreSQL database password created
# during project setup. The system will auto-construct the connection pooler URL.
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Backend Supabase API credentials (used for verification)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Allowed CORS origin URL (should match your frontend client URL)
CORS_ORIGIN=http://localhost:3000

# API Rate Limiting configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
