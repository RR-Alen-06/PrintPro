# ============================================================
#  PrintPro – .gitignore
# ============================================================

# ------ Dependencies ----------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ------ Environment variables (NEVER commit secrets) --------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
frontend/.env*
!frontend/.env.example
backend/.env*
!backend/.env.example

# ------ Production / Build output ---------------------------
dist/
build/
out/
.next/
.nuxt/
.output/

# ------ Vite ------------------------------------------------
vite.config.js.timestamp-*

# ------ Logs ------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------ Runtime / OS ----------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ------ IDEs ------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ------ Testing & Coverage ----------------------------------
coverage/
.nyc_output/
*.lcov

# ------ Temporary / Cache -----------------------------------
*.tmp
*.bak
*.orig
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache

# ------ Uploads (user-generated files) ----------------------
backend/uploads/

# ------ MySQL / Database dumps ------------------------------
*.sql.gz
*.dump

# ------ Misc ------------------------------------------------
.expo/
.vercel/
.netlify/
